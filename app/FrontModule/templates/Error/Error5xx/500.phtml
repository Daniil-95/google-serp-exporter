<!DOCTYPE html>
<html lang="cs">
    <head>
        <meta charset="utf-8">
        <meta name="robots" content="noindex">
        <meta name="viewport" content="width=device-width, initial-scale=1">

        <title>Server Error | Google SERP Exporter</title>

        <link rel="stylesheet" href="/css/main.css">
    </head>
    <body>
        <div class="error-page">
            <div class="error-card">
                <div class="error-icon">
                    ⚙️
                </div>

                <div class="error-code error-code--500">
                    Error 500
                </div>

                <h1 class="error-title">
                    Server Error
                </h1>

                <p class="error-description">
                    Při zpracování požadavku došlo k neočekávané chybě.
                    Zkuste stránku obnovit nebo se vraťte na hlavní stránku aplikace.
                </p>

                <div class="actions">
                    <a href="/" class="error-button">
                        Domovská stránka
                    </a>

                    <a href="javascript:location.reload()" class="error-button error-button--secondary">
                        Obnovit stránku
                    </a>
                </div>

                <div class="error-footer">
                    Google SERP Exporter • PHP 8.3 • Nette Framework
                </div>
            </div>
        </div>
    </body>
</html>