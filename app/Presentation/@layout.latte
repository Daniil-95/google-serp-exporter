<!DOCTYPE html>
<html lang="cs">
	<head>
		<meta charset="utf-8">
		<meta name="viewport" content="width=device-width, initial-scale=1">

		<title>{ifset title}{include title|stripHtml} | {/ifset}Google SERP Exporter</title>

		<meta name="description" content="Google SERP Exporter - export organických výsledků z první stránky Google do strukturovaného formátu.">

		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">

		<link rel="stylesheet" href="/css/main.css">
	</head>

	<body>
		{if $flashes}
			<div class="flash-wrapper">
				<div n:foreach="$flashes as $flash" n:class="flash, $flash->type">
					{$flash->message}
				</div>
			</div>
		{/if}

		<main>
			{include content}
		</main>

		<script src="/js/main.js"></script>
	</body>
</html>