# see https://doc.nette.org/en/configuring

parameters:


application:
	errorPresenter:
		4xx: Error4xx
		5xx: Error5xx
	mapping:
		'*': App\FrontModule\Presenters\*Presenter


database:
	dsn: 'sqlite::memory:'
	user:
	password:


latte:
	strictParsing: yes
	extensions:
		- App\FrontModule\Presenters\LatteExtension


assets:
	mapping:
		default:
			path: assets
			# type: vite  # Odkomentovat pro aktivaci Vite


di:
	export:
		parameters: no
		tags: no
